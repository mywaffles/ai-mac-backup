#!/usr/bin/env bash
# ai-restore — restore paths listed in ~/ai-backup-mac/backup-paths.conf
# Usage:
#   ai-restore              → list available backups
#   ai-restore --last       → restore from most recent backup
#   ai-restore <commit>     → restore from specific commit hash

set -euo pipefail

REPO="$HOME/ai-backup-mac"
CONF="$REPO/backup-paths.conf"
LOG="$REPO/ai-backup.log"
BAK_SUFFIX=".bak-$(date '+%Y%m%d-%H%M%S')"
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

if [ ! -d "$REPO/.git" ]; then
  echo "❌ Repo not found at $REPO"
  exit 1
fi

cd "$REPO"

# ── Default: list backups ────────────────────────────────────────────────────
if [ "${1:-}" = "" ]; then
  echo "📋 Available backups (most recent first):"
  echo ""
  git log --pretty=format:"%C(yellow)%h%Creset  %C(cyan)%ai%Creset  %s" --grep="^backup:" | head -20
  echo ""
  echo "Usage:"
  echo "  ai-restore --last         restore most recent backup"
  echo "  ai-restore <commit>       restore from specific commit hash"
  exit 0
fi

# ── Determine target commit ──────────────────────────────────────────────────
if [ "${1}" = "--last" ]; then
  TARGET=$(git log -1 --pretty=format:"%h" --grep="^backup:")
  if [ -z "$TARGET" ]; then
    echo "❌ No backups found."
    exit 1
  fi
  LABEL="last backup"
else
  TARGET="${1}"
  LABEL="commit $TARGET"
fi

echo "🔄 ai-restore from $LABEL"
echo ""

COMMIT_MSG=$(git log -1 --pretty=format:"%h %s (%ai)" "$TARGET" 2>/dev/null || echo "unknown")
echo "📌 Target: $COMMIT_MSG"
echo ""

# ── Checkout target into temp dir ────────────────────────────────────────────
TMPDIR_RESTORE=$(mktemp -d)
trap "rm -rf $TMPDIR_RESTORE" EXIT

git --work-tree="$TMPDIR_RESTORE" checkout "$TARGET" -- . 2>/dev/null || true

# ── Diff backup vs live, building restore plan ───────────────────────────────
CHANGED=""

while IFS= read -r line; do
  [[ "$line" =~ ^[[:space:]]*$ ]] && continue
  [[ "$line" =~ ^[[:space:]]*# ]] && continue

  SOURCE="${line/\~/$HOME}"
  DEST_NAME=$(basename "$SOURCE")

  if [ -f "$SOURCE" ]; then
    PARENT=$(basename "$(dirname "$SOURCE")")
    PARENT="${PARENT/Application Support/app-support}"
    REPO_COPY="$TMPDIR_RESTORE/files/$PARENT/$DEST_NAME"
    [ -f "$REPO_COPY" ] && { diff -q "$REPO_COPY" "$SOURCE" 2>/dev/null || CHANGED+="  $line differs"$'\n'; }
  elif [ -d "$SOURCE" ]; then
    REPO_COPY="$TMPDIR_RESTORE/$DEST_NAME"
    [ -d "$REPO_COPY" ] && CHANGED+=$(diff -rq "$REPO_COPY" "$SOURCE" 2>/dev/null | sed 's/^/  /' || true)
  fi
done < "$CONF"

if [ -z "$CHANGED" ]; then
  echo "✅ No differences from current state — nothing to restore."
  echo "[$TIMESTAMP] RESTORE: no differences from $COMMIT_MSG" >> "$LOG"
  exit 0
fi

echo "📝 Differences between backup and current state:"
echo "$CHANGED"
echo ""

read -r -p "⚠️  Restore from backup? Existing files will be renamed to *${BAK_SUFFIX}. [y/N] " confirm
if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
  echo "Cancelled."
  echo "[$TIMESTAMP] RESTORE: cancelled (target: $COMMIT_MSG)" >> "$LOG"
  exit 0
fi

echo ""
echo "📁 Renaming existing files with suffix: $BAK_SUFFIX"
echo ""

RENAMED=()

# ── Restore each path ────────────────────────────────────────────────────────
while IFS= read -r line; do
  [[ "$line" =~ ^[[:space:]]*$ ]] && continue
  [[ "$line" =~ ^[[:space:]]*# ]] && continue

  SOURCE="${line/\~/$HOME}"
  DEST_NAME=$(basename "$SOURCE")

  if [ -f "$SOURCE" ]; then
    PARENT=$(basename "$(dirname "$SOURCE")")
    PARENT="${PARENT/Application Support/app-support}"
    REPO_COPY="$TMPDIR_RESTORE/files/$PARENT/$DEST_NAME"
    if [ -f "$REPO_COPY" ]; then
      if [ -f "$SOURCE" ]; then
        mv "$SOURCE" "${SOURCE}${BAK_SUFFIX}"
        echo "  ← renamed: ${line}${BAK_SUFFIX}"
        RENAMED+=("${line}${BAK_SUFFIX}")
      fi
      cp "$REPO_COPY" "$SOURCE"
      echo "  → $line"
    fi
  elif [ -d "$SOURCE" ]; then
    REPO_COPY="$TMPDIR_RESTORE/$DEST_NAME"
    if [ -d "$REPO_COPY" ]; then
      if [ -d "$SOURCE" ]; then
        mv "$SOURCE" "${SOURCE}${BAK_SUFFIX}"
        echo "  ← renamed: ${line}${BAK_SUFFIX}"
        RENAMED+=("${line}${BAK_SUFFIX}")
      fi
      rsync -a "$REPO_COPY/" "$SOURCE/"
      echo "  → $line"
    fi
  fi
done < "$CONF"

# Reset repo working tree
git checkout HEAD -- . 2>/dev/null || true

# ── Log & push ────────────────────────────────────────────────────────────────
{
  echo "[$TIMESTAMP] RESTORE from $COMMIT_MSG"
  echo "  Renamed (bad files preserved at):"
  for r in "${RENAMED[@]}"; do
    echo "    $r"
  done
  echo ""
} >> "$LOG"

git add "$LOG"
git diff --staged --quiet || git commit -m "log: restore at $TIMESTAMP"
git push

echo ""
echo "✅ Restore complete from: $COMMIT_MSG"
echo ""
echo "💡 Bad files renamed with suffix: $BAK_SUFFIX"
echo "💡 Restart Claude Desktop for changes to take effect."
