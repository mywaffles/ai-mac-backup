#!/usr/bin/env bash
# ai-restore — restore paths listed in ~/ai-backup-mac/backup-paths.conf
# Usage:
#   ai-restore              → list available backups
#   ai-restore --last       → restore from most recent backup
#   ai-restore <commit>     → restore from specific commit hash

set -euo pipefail

REPO="$HOME/ai-backup-mac"
CONF="$REPO/backup-paths.conf"
LOG="$REPO/ai-backup.log"
BAK_SUFFIX=".bak-$(date '+%Y%m%d-%H%M%S')"
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

# ── Guards ───────────────────────────────────────────────────────────────────
[ -d "$REPO/.git" ] || { echo "❌ Repo not found at $REPO"; exit 1; }
[ -f "$CONF" ]      || { echo "❌ Config not found at $CONF"; exit 1; }

cd "$REPO"

# ── Shared: resolve dest path for a source path ──────────────────────────────
dest_for() {
  local src="$1"
  local name; name=$(basename "$src")
  if [ -f "$src" ] || [[ "$src" != */ ]] && [ ! -d "$src" ]; then
    # treat as file path (may not exist on disk yet if restoring)
    local parent; parent=$(basename "$(dirname "$src")" | tr ' ' '-')
    echo "files/$parent/$name"
  else
    echo "$name"
  fi
}

# ── List mode ────────────────────────────────────────────────────────────────
if [ "${1:-}" = "" ]; then
  echo "📋 Available backups (most recent first):"
  echo ""
  git log --pretty=format:"%C(yellow)%h%Creset  %C(cyan)%ai%Creset  %s" --grep="^backup:" | head -20
  echo ""
  echo "Usage:"
  echo "  ai-restore --last         restore most recent backup"
  echo "  ai-restore <commit>       restore from specific commit hash"
  exit 0
fi

# ── Resolve target commit ─────────────────────────────────────────────────────
if [ "${1}" = "--last" ]; then
  TARGET=$(git log -1 --pretty=format:"%h" --grep="^backup:")
  [ -n "$TARGET" ] || { echo "❌ No backups found."; exit 1; }
  LABEL="last backup"
else
  TARGET="${1}"
  LABEL="commit $TARGET"
fi

COMMIT_MSG=$(git log -1 --pretty=format:"%h %s (%ai)" "$TARGET" 2>/dev/null || echo "unknown")
echo "🔄 ai-restore from $LABEL"
echo "📌 Target: $COMMIT_MSG"
echo ""

# ── Checkout target into temp dir ─────────────────────────────────────────────
TMPDIR_RESTORE=$(mktemp -d)
trap 'rm -rf "$TMPDIR_RESTORE"' EXIT
git --work-tree="$TMPDIR_RESTORE" checkout "$TARGET" -- . 2>/dev/null || true

# ── Build restore plan: collect (source, repo_copy) pairs that differ ─────────
declare -a PLAN_SRC=()
declare -a PLAN_REPO=()
CHANGED=""

while IFS= read -r line; do
  [[ "$line" =~ ^[[:space:]]*$  ]] && continue
  [[ "$line" =~ ^[[:space:]]*# ]] && continue

  SOURCE="${line/#\~/$HOME}"
  DEST_REL=$(dest_for "$SOURCE")
  REPO_COPY="$TMPDIR_RESTORE/$DEST_REL"

  if [ -f "$SOURCE" ]; then
    if [ -f "$REPO_COPY" ] && ! diff -q "$REPO_COPY" "$SOURCE" &>/dev/null; then
      CHANGED+="  $line differs"$'\n'
      PLAN_SRC+=("$SOURCE")
      PLAN_REPO+=("$REPO_COPY")
    fi
  elif [ -d "$SOURCE" ]; then
    if [ -d "$REPO_COPY" ]; then
      DIFF=$(diff -rq "$REPO_COPY" "$SOURCE" 2>/dev/null | sed 's/^/  /' || true)
      if [ -n "$DIFF" ]; then
        CHANGED+="$DIFF"$'\n'
        PLAN_SRC+=("$SOURCE")
        PLAN_REPO+=("$REPO_COPY")
      fi
    fi
  fi
done < "$CONF"

if [ -z "$CHANGED" ]; then
  echo "✅ No differences from current state — nothing to restore."
  printf '[%s] RESTORE: no differences from %s\n\n' "$TIMESTAMP" "$COMMIT_MSG" >> "$LOG"
  exit 0
fi

echo "📝 Differences between backup and current state:"
echo "$CHANGED"

read -r -p "⚠️  Restore from backup? Existing files will be renamed *${BAK_SUFFIX}. [y/N] " confirm
if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
  echo "Cancelled."
  printf '[%s] RESTORE: cancelled (target: %s)\n\n' "$TIMESTAMP" "$COMMIT_MSG" >> "$LOG"
  exit 0
fi

echo ""
echo "📁 Renaming existing files with suffix: $BAK_SUFFIX"
echo ""

RENAMED=()

# ── Execute restore plan ──────────────────────────────────────────────────────
for i in "${!PLAN_SRC[@]}"; do
  SOURCE="${PLAN_SRC[$i]}"
  REPO_COPY="${PLAN_REPO[$i]}"

  if [ -f "$SOURCE" ]; then
    mv "$SOURCE" "${SOURCE}${BAK_SUFFIX}"
    echo "  ← renamed: ${SOURCE/#$HOME/\~}${BAK_SUFFIX}"
    RENAMED+=("${SOURCE/#$HOME/\~}${BAK_SUFFIX}")
    cp "$REPO_COPY" "$SOURCE"
    echo "  → ${SOURCE/#$HOME/\~}"

  elif [ -d "$SOURCE" ]; then
    mv "$SOURCE" "${SOURCE}${BAK_SUFFIX}"
    echo "  ← renamed: ${SOURCE/#$HOME/\~}${BAK_SUFFIX}"
    RENAMED+=("${SOURCE/#$HOME/\~}${BAK_SUFFIX}")
    rsync -a "$REPO_COPY/" "$SOURCE/"
    echo "  → ${SOURCE/#$HOME/\~}"
  fi
done

# Reset repo working tree
git checkout HEAD -- . 2>/dev/null || true

# ── Log & push ────────────────────────────────────────────────────────────────
{
  printf '[%s] RESTORE from %s\n' "$TIMESTAMP" "$COMMIT_MSG"
  echo "  Renamed (bad files preserved at):"
  for r in "${RENAMED[@]}"; do printf '    %s\n' "$r"; done
  echo ""
} >> "$LOG"

git add "$LOG"
git diff --staged --quiet || git commit -m "log: restore at $TIMESTAMP"
git push

echo ""
echo "✅ Restore complete from: $COMMIT_MSG"
echo "💡 Bad files renamed with suffix: $BAK_SUFFIX"
echo "💡 Restart Claude Desktop for changes to take effect."
