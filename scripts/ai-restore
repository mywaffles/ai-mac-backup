#!/usr/bin/env bash
# ai-restore — restore paths listed in ~/ai-backup-mac/backup-paths.conf
# Usage:
#   ai-restore              → list available backups
#   ai-restore --last       → restore most recent backup (exact snapshot)
#   ai-restore <commit>     → restore exact snapshot at that commit

set -euo pipefail

REPO="$HOME/ai-backup-mac"
CONF="$REPO/backup-paths.conf"
LOG="$REPO/ai-backup.log"
BAK_SUFFIX=".bak-$(date '+%Y%m%d-%H%M%S')"
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

# ── Guards ────────────────────────────────────────────────────────────────────
[ -d "$REPO/.git" ] || { echo "❌ Repo not found at $REPO"; exit 1; }
[ -f "$CONF" ]      || { echo "❌ Config not found at $CONF"; exit 1; }

cd "$REPO"

# ── Shared: resolve repo-relative dest for a live source path ────────────────
dest_for() {
  local src="$1"
  local name; name=$(basename "$src")
  if [ -f "$src" ] || { [[ "$src" != */ ]] && [ ! -d "$src" ]; }; then
    local parent; parent=$(basename "$(dirname "$src")" | tr ' ' '-')
    echo "files/$parent/$name"
  else
    echo "$name"
  fi
}

# ── List mode ─────────────────────────────────────────────────────────────────
if [ "${1:-}" = "" ]; then
  echo "📋 Available backups (most recent first):"
  echo ""
  git log --pretty=format:"%C(yellow)%h%Creset  %C(cyan)%ai%Creset  %s" --grep="^backup:" | head -20
  echo ""
  echo "Usage:"
  echo "  ai-restore --last         restore most recent backup"
  echo "  ai-restore <commit>       restore exact snapshot at that commit"
  exit 0
fi

# ── Resolve target commit ─────────────────────────────────────────────────────
if [ "${1}" = "--last" ]; then
  TARGET=$(git log -1 --pretty=format:"%h" --grep="^backup:")
  [ -n "$TARGET" ] || { echo "❌ No backups found."; exit 1; }
  LABEL="last backup"
else
  TARGET="${1}"
  LABEL="commit $TARGET"
fi

COMMIT_MSG=$(git log -1 --pretty=format:"%h %s (%ai)" "$TARGET" 2>/dev/null || echo "unknown")
echo "🔄 ai-restore from $LABEL"
echo "📌 Target: $COMMIT_MSG"
echo ""

# ── Checkout target snapshot into temp dir ───────────────────────────────────
TMPDIR_RESTORE=$(mktemp -d)
trap 'rm -rf "$TMPDIR_RESTORE"' EXIT
git --work-tree="$TMPDIR_RESTORE" checkout "$TARGET" -- . 2>/dev/null || true

# ── Read backup-paths.conf FROM THE SNAPSHOT (not current) ───────────────────
# This ensures we restore exactly what was tracked at that point in time.
SNAPSHOT_CONF="$TMPDIR_RESTORE/backup-paths.conf"
[ -f "$SNAPSHOT_CONF" ] || { echo "❌ backup-paths.conf not found in snapshot"; exit 1; }

# ── Warn if scripts or backup-paths.conf differ ──────────────────────────────
SCRIPTS_CHANGED=""
if [ -d "$TMPDIR_RESTORE/scripts" ]; then
  SDIFF=$(diff -rq "$TMPDIR_RESTORE/scripts" "$REPO/scripts" 2>/dev/null || true)
  [ -n "$SDIFF" ] && SCRIPTS_CHANGED="$SDIFF"
fi
if ! diff -q "$SNAPSHOT_CONF" "$CONF" &>/dev/null; then
  SCRIPTS_CHANGED+=$'\n'"  backup-paths.conf differs"
fi

if [ -n "$SCRIPTS_CHANGED" ]; then
  echo "⚠️  Note: this snapshot has different versions of:"
  echo "$SCRIPTS_CHANGED" | sed 's/^/  /'
  echo ""
  echo "  These are the backup scripts and path config themselves."
  echo "  They will NOT be overwritten unless you say yes below."
  echo "  (They live in the repo at ~/ai-backup-mac/, not in the backed-up paths.)"
  echo ""
fi

# ── Build restore plan from the snapshot's backup-paths.conf ─────────────────
declare -a PLAN_SRC=()
declare -a PLAN_REPO=()
CHANGED=""

while IFS= read -r line; do
  [[ "$line" =~ ^[[:space:]]*$  ]] && continue
  [[ "$line" =~ ^[[:space:]]*# ]] && continue

  SOURCE="${line/#\~/$HOME}"
  DEST_REL=$(dest_for "$SOURCE")
  REPO_COPY="$TMPDIR_RESTORE/$DEST_REL"

  if [ -f "$SOURCE" ]; then
    if [ -f "$REPO_COPY" ] && ! diff -q "$REPO_COPY" "$SOURCE" &>/dev/null; then
      CHANGED+="  $line differs"$'\n'
      PLAN_SRC+=("$SOURCE")
      PLAN_REPO+=("$REPO_COPY")
    fi
  elif [ -d "$SOURCE" ]; then
    if [ -d "$REPO_COPY" ]; then
      DIFF=$(diff -rq "$REPO_COPY" "$SOURCE" 2>/dev/null | sed 's/^/  /' || true)
      if [ -n "$DIFF" ]; then
        CHANGED+="$DIFF"$'\n'
        PLAN_SRC+=("$SOURCE")
        PLAN_REPO+=("$REPO_COPY")
      fi
    fi
  fi
done < "$SNAPSHOT_CONF"

if [ -z "$CHANGED" ]; then
  echo "✅ No differences from current state — nothing to restore."
  printf '[%s] RESTORE: no differences from %s\n\n' "$TIMESTAMP" "$COMMIT_MSG" >> "$LOG"
  exit 0
fi

echo "📝 Differences between snapshot and current state:"
echo "$CHANGED"

read -r -p "⚠️  Restore from backup? Existing files will be renamed *${BAK_SUFFIX}. [y/N] " confirm
if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
  echo "Cancelled."
  printf '[%s] RESTORE: cancelled (target: %s)\n\n' "$TIMESTAMP" "$COMMIT_MSG" >> "$LOG"
  exit 0
fi

echo ""
echo "📁 Renaming existing files with suffix: $BAK_SUFFIX"
echo ""

RENAMED=()

# ── Execute restore plan ──────────────────────────────────────────────────────
for i in "${!PLAN_SRC[@]}"; do
  SOURCE="${PLAN_SRC[$i]}"
  REPO_COPY="${PLAN_REPO[$i]}"

  if [ -f "$SOURCE" ]; then
    mv "$SOURCE" "${SOURCE}${BAK_SUFFIX}"
    echo "  ← renamed: ${SOURCE/#$HOME/\~}${BAK_SUFFIX}"
    RENAMED+=("${SOURCE/#$HOME/\~}${BAK_SUFFIX}")
    cp "$REPO_COPY" "$SOURCE"
    echo "  → ${SOURCE/#$HOME/\~}"
  elif [ -d "$SOURCE" ]; then
    mv "$SOURCE" "${SOURCE}${BAK_SUFFIX}"
    echo "  ← renamed: ${SOURCE/#$HOME/\~}${BAK_SUFFIX}"
    RENAMED+=("${SOURCE/#$HOME/\~}${BAK_SUFFIX}")
    rsync -a "$REPO_COPY/" "$SOURCE/"
    echo "  → ${SOURCE/#$HOME/\~}"
  fi
done

# Reset repo working tree to HEAD (don't leave it in detached state)
git checkout HEAD -- . 2>/dev/null || true

# ── Log & push ────────────────────────────────────────────────────────────────
{
  printf '[%s] RESTORE from %s\n' "$TIMESTAMP" "$COMMIT_MSG"
  echo "  Renamed (bad files preserved at):"
  for r in "${RENAMED[@]}"; do printf '    %s\n' "$r"; done
  echo ""
} >> "$LOG"

git add "$LOG"
git diff --staged --quiet || git commit -m "log: restore at $TIMESTAMP"
git push

echo ""
echo "✅ Restore complete from: $COMMIT_MSG"
echo "💡 Bad files renamed with suffix: $BAK_SUFFIX"
echo "💡 Restart Claude Desktop for changes to take effect."
