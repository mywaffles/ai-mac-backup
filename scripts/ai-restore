#!/usr/bin/env bash
# ai-restore — restore Claude/AI config dirs from ~/ai-backup-mac
# Usage:
#   ai-restore              → list available backups
#   ai-restore --last       → restore from most recent backup
#   ai-restore <commit>     → restore from specific commit hash

set -euo pipefail

REPO="$HOME/ai-backup-mac"
LOG="$REPO/ai-backup.log"
BAK_SUFFIX=".bak-$(date '+%Y%m%d-%H%M%S')"
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

if [ ! -d "$REPO/.git" ]; then
  echo "❌ Repo not found at $REPO"
  exit 1
fi

cd "$REPO"

# ── Default: list backups ────────────────────────────────────────────────────
if [ "${1:-}" = "" ]; then
  echo "📋 Available backups (most recent first):"
  echo ""
  git log --pretty=format:"%C(yellow)%h%Creset  %C(cyan)%ai%Creset  %s" --grep="^backup:" | head -20
  echo ""
  echo "Usage:"
  echo "  ai-restore --last         restore most recent backup"
  echo "  ai-restore <commit>       restore from specific commit hash"
  exit 0
fi

# ── Determine target commit ──────────────────────────────────────────────────
if [ "${1}" = "--last" ]; then
  TARGET=$(git log -1 --pretty=format:"%h" --grep="^backup:")
  if [ -z "$TARGET" ]; then
    echo "❌ No backups found."
    exit 1
  fi
  LABEL="last backup"
else
  TARGET="${1}"
  LABEL="commit $TARGET"
fi

echo "🔄 ai-restore from $LABEL"
echo ""

COMMIT_MSG=$(git log -1 --pretty=format:"%h %s (%ai)" "$TARGET" 2>/dev/null || echo "unknown")
echo "📌 Target: $COMMIT_MSG"
echo ""

# ── Checkout target into temp dir and diff vs live ───────────────────────────
TMPDIR_PREVIEW=$(mktemp -d)
trap "rm -rf $TMPDIR_PREVIEW" EXIT

git --work-tree="$TMPDIR_PREVIEW" checkout "$TARGET" -- skills/ shell/ claude-desktop/ claude-code/ 2>/dev/null || true

CHANGED=""
CLAUDE_DIR="$HOME/Library/Application Support/Claude"

[ -d "$TMPDIR_PREVIEW/skills" ] && CHANGED+=$(diff -rq "$TMPDIR_PREVIEW/skills" "$HOME/.agents/skills" 2>/dev/null | sed 's/^/  /' || true)

for f in .zprofile .bashrc .bash_profile; do
  [ -f "$TMPDIR_PREVIEW/shell/$f" ] && { diff -q "$TMPDIR_PREVIEW/shell/$f" "$HOME/$f" 2>/dev/null || CHANGED+="  shell/$f differs"$'\n'; }
done

for f in claude_desktop_config.json config.json window-state.json git-worktrees.json; do
  [ -f "$TMPDIR_PREVIEW/claude-desktop/$f" ] && { diff -q "$TMPDIR_PREVIEW/claude-desktop/$f" "$CLAUDE_DIR/$f" 2>/dev/null || CHANGED+="  claude-desktop/$f differs"$'\n'; }
done

[ -d "$TMPDIR_PREVIEW/claude-code" ] && CHANGED+=$(diff -rq "$TMPDIR_PREVIEW/claude-code" "$HOME/.claude" 2>/dev/null | sed 's/^/  /' || true)

if [ -z "$CHANGED" ]; then
  echo "✅ No differences from current state — nothing to restore."
  echo "[$TIMESTAMP] RESTORE: no differences from $COMMIT_MSG" >> "$LOG"
  exit 0
fi

echo "📝 Differences between backup and current state:"
echo "$CHANGED"
echo ""

read -r -p "⚠️  Restore from backup? Existing files will be renamed to *${BAK_SUFFIX}. [y/N] " confirm
if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
  echo "Cancelled."
  echo "[$TIMESTAMP] RESTORE: cancelled by user (target: $COMMIT_MSG)" >> "$LOG"
  exit 0
fi

echo ""
echo "📁 Backup suffix: $BAK_SUFFIX"
echo ""

# Track renamed files for log
RENAMED=()

# ── Restore skills ───────────────────────────────────────────────────────────
if [ -d "$TMPDIR_PREVIEW/skills" ]; then
  echo "📦 Restoring skills..."
  if [ -d "$HOME/.agents/skills" ]; then
    mv "$HOME/.agents/skills" "$HOME/.agents/skills${BAK_SUFFIX}"
    echo "   ← renamed: ~/.agents/skills${BAK_SUFFIX}"
    RENAMED+=("~/.agents/skills${BAK_SUFFIX}")
  fi
  rsync -a "$TMPDIR_PREVIEW/skills/" "$HOME/.agents/skills/"
  echo "   → ~/.agents/skills/"
fi

# ── Restore shell config ─────────────────────────────────────────────────────
if [ -d "$TMPDIR_PREVIEW/shell" ]; then
  echo "🐚 Restoring shell config..."
  for f in .zprofile .bashrc .bash_profile; do
    if [ -f "$TMPDIR_PREVIEW/shell/$f" ]; then
      if [ -f "$HOME/$f" ]; then
        mv "$HOME/$f" "$HOME/$f${BAK_SUFFIX}"
        echo "   ← renamed: ~/$f${BAK_SUFFIX}"
        RENAMED+=("~/$f${BAK_SUFFIX}")
      fi
      cp "$TMPDIR_PREVIEW/shell/$f" "$HOME/$f"
      echo "   → ~/$f"
    fi
  done
fi

# ── Restore Claude Desktop config ────────────────────────────────────────────
if [ -d "$TMPDIR_PREVIEW/claude-desktop" ]; then
  echo "🤖 Restoring Claude Desktop config..."
  for f in claude_desktop_config.json config.json window-state.json git-worktrees.json; do
    if [ -f "$TMPDIR_PREVIEW/claude-desktop/$f" ]; then
      if [ -f "$CLAUDE_DIR/$f" ]; then
        mv "$CLAUDE_DIR/$f" "$CLAUDE_DIR/$f${BAK_SUFFIX}"
        echo "   ← renamed: $f${BAK_SUFFIX}"
        RENAMED+=("Claude/$f${BAK_SUFFIX}")
      fi
      cp "$TMPDIR_PREVIEW/claude-desktop/$f" "$CLAUDE_DIR/$f"
      echo "   → $f"
    fi
  done
fi

# ── Restore Claude Code settings ─────────────────────────────────────────────
if [ -d "$TMPDIR_PREVIEW/claude-code" ]; then
  echo "💻 Restoring Claude Code settings..."
  if [ -d "$HOME/.claude" ]; then
    mv "$HOME/.claude" "$HOME/.claude${BAK_SUFFIX}"
    echo "   ← renamed: ~/.claude${BAK_SUFFIX}"
    RENAMED+=("~/.claude${BAK_SUFFIX}")
  fi
  rsync -a "$TMPDIR_PREVIEW/claude-code/" "$HOME/.claude/"
  echo "   → ~/.claude/"
fi

# Reset repo working tree back to HEAD
git checkout HEAD -- . 2>/dev/null || true

# ── Log ───────────────────────────────────────────────────────────────────────
{
  echo "[$TIMESTAMP] RESTORE from $COMMIT_MSG"
  echo "  Renamed (bad files preserved at):"
  for r in "${RENAMED[@]}"; do
    echo "    $r"
  done
  echo ""
} >> "$LOG"

# ── Commit the log update ─────────────────────────────────────────────────────
git add "$LOG"
git diff --staged --quiet || git commit -m "log: restore at $TIMESTAMP"
git push

echo ""
echo "✅ Restore complete from: $COMMIT_MSG"
echo ""
echo "💡 Bad files renamed with suffix: $BAK_SUFFIX"
echo "💡 Restart Claude Desktop for changes to take effect."
