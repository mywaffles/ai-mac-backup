#!/usr/bin/env bash
# ai-restore — restore Claude/AI config dirs from ~/ai-mac-backup
# Usage:
#   ai-restore              → list available backups
#   ai-restore --last       → restore from most recent backup
#   ai-restore <commit>     → restore from specific commit hash

set -euo pipefail

REPO="$HOME/ai-mac-backup"

if [ ! -d "$REPO/.git" ]; then
  echo "❌ Repo not found at $REPO"
  exit 1
fi

cd "$REPO"

# ── Default: list backups ────────────────────────────────────────────────────
if [ "${1:-}" = "" ]; then
  echo "📋 Available backups (most recent first):"
  echo ""
  git log --pretty=format:"%C(yellow)%h%Creset  %C(cyan)%ai%Creset  %s" --grep="^backup:" | head -20
  echo ""
  echo "Usage:"
  echo "  ai-restore --last         restore most recent backup"
  echo "  ai-restore <commit>       restore from specific commit hash"
  exit 0
fi

# ── Determine target commit ──────────────────────────────────────────────────
if [ "${1}" = "--last" ]; then
  TARGET=$(git log -1 --pretty=format:"%h" --grep="^backup:")
  if [ -z "$TARGET" ]; then
    echo "❌ No backups found."
    exit 1
  fi
  LABEL="last backup"
else
  TARGET="${1}"
  LABEL="commit $TARGET"
fi

echo "🔄 ai-restore from $LABEL"
echo ""

COMMIT_MSG=$(git log -1 --pretty=format:"%h %s (%ai)" "$TARGET" 2>/dev/null || echo "unknown")
echo "📌 Target: $COMMIT_MSG"
echo ""

# ── Preview: check out target into temp dir and diff vs live filesystem ──────
TMPDIR_PREVIEW=$(mktemp -d)
trap "rm -rf $TMPDIR_PREVIEW" EXIT

git --work-tree="$TMPDIR_PREVIEW" checkout "$TARGET" -- skills/ shell/ claude-desktop/ claude-code/ 2>/dev/null || true

CHANGED=""

# Compare skills
[ -d "$TMPDIR_PREVIEW/skills" ] && CHANGED+=$(diff -rq "$TMPDIR_PREVIEW/skills" "$HOME/.agents/skills" 2>/dev/null | sed 's/^/  /' || true)

# Compare shell
for f in .zprofile .bashrc .bash_profile; do
  if [ -f "$TMPDIR_PREVIEW/shell/$f" ]; then
    diff -q "$TMPDIR_PREVIEW/shell/$f" "$HOME/$f" 2>/dev/null || CHANGED+="  shell/$f differs"$'\n'
  fi
done

# Compare claude-desktop
CLAUDE_DIR="$HOME/Library/Application Support/Claude"
for f in claude_desktop_config.json config.json window-state.json git-worktrees.json; do
  if [ -f "$TMPDIR_PREVIEW/claude-desktop/$f" ]; then
    diff -q "$TMPDIR_PREVIEW/claude-desktop/$f" "$CLAUDE_DIR/$f" 2>/dev/null || CHANGED+="  claude-desktop/$f differs"$'\n'
  fi
done

# Compare claude-code
[ -d "$TMPDIR_PREVIEW/claude-code" ] && CHANGED+=$(diff -rq "$TMPDIR_PREVIEW/claude-code" "$HOME/.claude" 2>/dev/null | sed 's/^/  /' || true)

if [ -z "$CHANGED" ]; then
  echo "✅ No differences from current state — nothing to restore."
  exit 0
fi

echo "📝 Differences between backup and current state:"
echo "$CHANGED"
echo ""

read -r -p "⚠️  Restore from backup? This will overwrite current versions. [y/N] " confirm
if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
  echo "Cancelled."
  exit 0
fi

echo ""

# ── Restore from the temp checkout ──────────────────────────────────────────
if [ -d "$TMPDIR_PREVIEW/skills" ]; then
  echo "📦 Restoring skills..."
  rsync -a --delete "$TMPDIR_PREVIEW/skills/" "$HOME/.agents/skills/"
  echo "   → ~/.agents/skills/"
fi

if [ -d "$TMPDIR_PREVIEW/shell" ]; then
  echo "🐚 Restoring shell config..."
  for f in .zprofile .bashrc .bash_profile; do
    [ -f "$TMPDIR_PREVIEW/shell/$f" ] && cp "$TMPDIR_PREVIEW/shell/$f" "$HOME/$f" && echo "   → ~/$f" || true
  done
fi

if [ -d "$TMPDIR_PREVIEW/claude-desktop" ]; then
  echo "🤖 Restoring Claude Desktop config..."
  for f in claude_desktop_config.json config.json window-state.json git-worktrees.json; do
    [ -f "$TMPDIR_PREVIEW/claude-desktop/$f" ] && cp "$TMPDIR_PREVIEW/claude-desktop/$f" "$CLAUDE_DIR/$f" && echo "   → $f" || true
  done
fi

if [ -d "$TMPDIR_PREVIEW/claude-code" ]; then
  echo "💻 Restoring Claude Code settings..."
  rsync -a --delete "$TMPDIR_PREVIEW/claude-code/" "$HOME/.claude/"
  echo "   → ~/.claude/"
fi

# Reset repo working tree back to HEAD
git checkout HEAD -- . 2>/dev/null || true

echo ""
echo "✅ Restore complete from: $COMMIT_MSG"
echo ""
echo "💡 Tip: Restart Claude Desktop for changes to take effect."
