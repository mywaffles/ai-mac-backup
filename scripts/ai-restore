#!/usr/bin/env bash
# ai-restore — restore Claude/AI config dirs from ~/ai-mac-backup
# Usage:
#   ai-restore              → restore from latest backup
#   ai-restore <commit>     → restore from specific commit hash or date
#   ai-restore --list       → show available backups

set -euo pipefail

REPO="$HOME/ai-mac-backup"

if [ ! -d "$REPO/.git" ]; then
  echo "❌ Repo not found at $REPO"
  exit 1
fi

cd "$REPO"

# ── List mode ────────────────────────────────────────────────────────────────
if [ "${1:-}" = "--list" ]; then
  echo "📋 Available backups:"
  git log --oneline --grep="^backup:" | head -20
  exit 0
fi

# ── Determine target commit ──────────────────────────────────────────────────
TARGET="${1:-HEAD}"

if [ "$TARGET" = "HEAD" ]; then
  LABEL="latest backup"
else
  LABEL="commit $TARGET"
fi

echo "🔄 ai-restore from $LABEL"
echo ""

# Show what the target looks like
COMMIT_MSG=$(git log -1 --pretty=format:"%h %s (%ai)" "$TARGET" 2>/dev/null || echo "unknown")
echo "📌 Target: $COMMIT_MSG"
echo ""

# Preview what will change
echo "📝 Files that will be restored:"
git diff --name-only "$TARGET" -- skills/ shell/ claude-desktop/ claude-code/ 2>/dev/null | sed 's/^/  /' || true
echo ""

read -r -p "⚠️  Restore these files? This will overwrite current versions. [y/N] " confirm
if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
  echo "Cancelled."
  exit 0
fi

echo ""

# ── Restore skills ───────────────────────────────────────────────────────────
if [ -d "$REPO/skills" ]; then
  echo "📦 Restoring skills..."
  git checkout "$TARGET" -- skills/ 2>/dev/null || true
  rsync -a --delete "$REPO/skills/" "$HOME/.agents/skills/"
  echo "   → ~/.agents/skills/"
fi

# ── Restore shell config ─────────────────────────────────────────────────────
if [ -d "$REPO/shell" ]; then
  echo "🐚 Restoring shell config..."
  git checkout "$TARGET" -- shell/ 2>/dev/null || true
  for f in .zshrc .zprofile .bashrc .bash_profile; do
    [ -f "$REPO/shell/$f" ] && cp "$REPO/shell/$f" "$HOME/$f" && echo "   → ~/$f" || true
  done
fi

# ── Restore Claude Desktop config ────────────────────────────────────────────
if [ -d "$REPO/claude-desktop" ]; then
  echo "🤖 Restoring Claude Desktop config..."
  git checkout "$TARGET" -- claude-desktop/ 2>/dev/null || true
  CLAUDE_DIR="$HOME/Library/Application Support/Claude"
  for f in claude_desktop_config.json config.json window-state.json git-worktrees.json; do
    [ -f "$REPO/claude-desktop/$f" ] && cp "$REPO/claude-desktop/$f" "$CLAUDE_DIR/$f" && echo "   → $f" || true
  done
fi

# ── Restore Claude Code settings ─────────────────────────────────────────────
if [ -d "$REPO/claude-code" ]; then
  echo "💻 Restoring Claude Code settings..."
  git checkout "$TARGET" -- claude-code/ 2>/dev/null || true
  rsync -a --delete "$REPO/claude-code/" "$HOME/.claude/"
  echo "   → ~/.claude/"
fi

# Reset git state back to HEAD after checkouts
git checkout HEAD -- . 2>/dev/null || true

echo ""
echo "✅ Restore complete from: $COMMIT_MSG"
echo ""
echo "💡 Tip: Restart Claude Desktop for changes to take effect."
