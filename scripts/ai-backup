#!/usr/bin/env bash
# ai-backup — snapshot paths listed in ~/ai-backup-mac/backup-paths.conf

set -euo pipefail

REPO="$HOME/ai-backup-mac"
CONF="$REPO/backup-paths.conf"
LOG="$REPO/ai-backup.log"
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

if [ ! -d "$REPO/.git" ]; then
  echo "❌ Repo not found at $REPO"
  exit 1
fi

if [ ! -f "$CONF" ]; then
  echo "❌ Config not found at $CONF"
  exit 1
fi

echo "🔄 ai-backup starting: $TIMESTAMP"
echo ""

# ── Sync each path from config ───────────────────────────────────────────────
while IFS= read -r line; do
  # Skip blank lines and comments
  [[ "$line" =~ ^[[:space:]]*$ ]] && continue
  [[ "$line" =~ ^[[:space:]]*# ]] && continue

  # Expand ~ 
  SOURCE="${line/\~/$HOME}"

  if [ ! -e "$SOURCE" ]; then
    echo "⚠️  Skipping (not found): $line"
    continue
  fi

  # Destination: last path component under repo
  DEST_NAME=$(basename "$SOURCE")
  # Group loose files by their parent dir name for clarity
  # Files go into a subdir named after their parent; dirs go in directly
  if [ -f "$SOURCE" ]; then
    PARENT=$(basename "$(dirname "$SOURCE")")
    # Simplify known verbose paths
    PARENT="${PARENT/Application Support/app-support}"
    DEST="$REPO/files/$PARENT"
    mkdir -p "$DEST"
    cp "$SOURCE" "$DEST/$DEST_NAME"
    echo "  📄 $line → files/$PARENT/$DEST_NAME"
  elif [ -d "$SOURCE" ]; then
    DEST="$REPO/$DEST_NAME"
    mkdir -p "$DEST"
    rsync -a --delete \
      --exclude='*.pyc' --exclude='__pycache__' --exclude='.DS_Store' \
      --exclude='*.log' --exclude='statsig/' --exclude='ide/' \
      "$SOURCE/" "$DEST/"
    echo "  📁 $line → $DEST_NAME/"
  fi

done < "$CONF"

# ── Git commit & push ────────────────────────────────────────────────────────
echo ""
cd "$REPO"

if git diff --quiet && git diff --staged --quiet && [ -z "$(git ls-files --others --exclude-standard)" ]; then
  echo "✅ Nothing changed since last backup."
  echo "[$TIMESTAMP] BACKUP: no changes" >> "$LOG"
  exit 0
fi

git add -A

echo "📝 Changes:"
CHANGES=$(git diff --staged --stat)
echo "$CHANGES"

git commit -m "backup: $TIMESTAMP"

echo ""
echo "⬆️  Pushing to GitHub..."
git push

{
  echo "[$TIMESTAMP] BACKUP"
  echo "$CHANGES" | sed 's/^/  /'
  echo ""
} >> "$LOG"

echo ""
echo "✅ Backup complete: $TIMESTAMP"
